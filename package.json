{
  "name": "spirit-api",
  "version": "1.0.0",
  "description": "NestJS skeleton application for Spirit system",
  "main": "dist/main.js",
  "scripts": {
    "build": "rimraf dist && nest build",
    "start": "nest start",
    "start:api:dev": "nest start --entryFile entrypoints/api/main --watch",
    "start:api": "node dist/entrypoints/api/main",
    "start:consumer:dev": "nest start --entryFile entrypoints/consumer/main --watch",
    "start:consumer": "node dist/entrypoints/consumer/main",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:all:dev": "concurrently \"npm run start:api:dev\" \"npm run start:consumer:dev\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test:ticket-import": "node test-scripts/send_ticket-import.js",
    "test:send_test": "node send_test.js",
    "test:send_order": "node send_order.js",
    "test:send_ticket_import": "node test-scripts/send_ticket_import.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/microservices": "^10.4.22",
    "@nestjs/platform-express": "^10.0.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^2.0.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "react-is": "^19.2.6",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "sequelize": "^6.37.8",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
